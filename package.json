{
  "name": "diu-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --prefix apps/mobile run start",
    "dev:all": "concurrently -n api,mobile -c blue,green \"npm run dev:api\" \"npm run dev\"",
    "dev:api": "npm --prefix apps/api run dev",
    "start": "npm --prefix apps/mobile run start",
    "android": "npm --prefix apps/mobile run android",
    "ios": "npm --prefix apps/mobile run ios",
    "web": "npm --prefix apps/mobile run web",
    "typecheck": "npm --prefix apps/mobile run typecheck && npm --prefix apps/api run typecheck",
    "test": "npm --prefix apps/mobile run test && npm --prefix apps/api run test",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.5.14"
  }
}
